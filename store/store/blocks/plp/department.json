{
  "search-result-layout#department": {
    "title": "Search Result Layout Department",
    "blocks": [
      "search-result-layout.desktop#department",
      "search-result-layout.mobile#department",
      "search-not-found-layout"
    ]
  },

  "search-result-layout.mobile#department": {
    "title": "Search Result Layout Mobile Department",
    "children": [
      "custom-category-banners#custom",
      "custom-search-carousel#default",
      "custom-div#orderby-and-counting-products",
      "filter-navigator.v3#custom",
      "search-content#default",
      "search-fetch-more",
      "custom-department-description#default"
    ],
    "props": {
      "pagination": "show-more",
      "preventRouteChange": false,
      "defaultGalleryLayout": "grid"
    }
  },

  "custom-department-description#default": {
    "props": {
      "title": "Feminino",
      "description": "A moda íntima feminina é uma peça chave para o dia a dia, oferecendo conforto e estilo. Na Riachuelo, você encontra uma variedade de modelos, como sutiãs, calcinhas, conjuntos, bodies, pijamas e meias, para todos os gostos e ocasiões. Nossas peças são desenvolvidas com materiais de alta qualidade, proporcionando um toque suave na pele e um caimento perfeito. Além disso, contamos com uma linha completa de moda praia, com biquínis, maiôs e saídas de praia, para você arrasar no verão. Descubra a coleção completa e renove seu guarda-roupa com as tendências da estação A moda íntima feminina é uma peça chave para o dia a dia, oferecendo conforto e estilo. Na Riachuelo, você encontra uma variedade de modelos, como sutiãs, calcinhas, conjuntos, bodies, pijamas e meias, para todos os gostos e ocasiões. Nossas peças são desenvolvidas com materiais de alta qualidade, proporcionando um toque suave na pele e um caimento perfeito. Além disso, contamos com uma linha completa de moda praia, com biquínis, maiôs e saídas de praia, para você arrasar no verão. Descubra a coleção completa e renove seu guarda-roupa com as tendências da estação A moda íntima feminina é uma peça chave para o dia a dia, oferecendo conforto e estilo. Na Riachuelo, você encontra uma variedade de modelos, como sutiãs, calcinhas, conjuntos, bodies, pijamas e meias, para todos os gostos e ocasiões. Nossas peças são desenvolvidas com materiais de alta qualidade, proporcionando um toque suave na pele e um caimento perfeito. Além disso, contamos com uma linha completa de moda praia, com biquínis, maiôs e saídas de praia, para você arrasar no verão. Descubra a coleção completa e renove seu guarda-roupa com as tendências da estação."
    }
  },

  "custom-div#orderby-and-counting-products": {
    "title": "Custom Order By and Counting Products",
    "props": {
      "blockClass": ["orderby-and-counting-products", "container"],
      "justifyContent": "space-between",
      "alignItems": "center",
      "flexDirectionMobile": "row",
      "preserveMobileLayout": true,
      "width": "100%",
      "margin": "8px 0px"
    },
    "children": ["total-products.v2", "order-by.v2"]
  },

