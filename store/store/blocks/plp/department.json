      "alt": "Banner Department",
      "width": "1440",
      "height": "300"
    }
  },
  "image#search-banner-department-mobile": {
    "props": {
      "blockClass": ["department-banner-image"],
      "src": "https://gruporios.vtexassets.com/assets/vtex.file-manager-graphql/images/aabe1c1d-d114-4fd4-b48a-0fb80c072680___9fd3a6b5a5e14919a8ad6b9e5b78260e.png",
      "alt": "Banner Department",
      "width": "1440",
      "height": "300"
    }
  },
  "custom-category-banners#custom": {
    "props": {
      "image": "https://gruporios.vtexassets.com/assets/vtex.file-manager-graphql/images/cf020d39-c96c-4561-b488-31a519ea7cb2___c0af3cc517588d682b995cc25de18e88.png",
      "mobileImage": "https://gruporios.vtexassets.com/assets/vtex.file-manager-graphql/images/aabe1c1d-d114-4fd4-b48a-0fb80c072680___9fd3a6b5a5e14919a8ad6b9e5b78260e.png",
      "blockClass": ["department-banner"],
      "showImageMobile": true,
      "showImageDesktop": true
    }
  }
}
