  "custom-div#filter-mobilev2": {
    "title": "Filter Container",
    "props": {
      "blockClass": ["filter-container", "container"],
      "justifyContent": "space-between",
      "alignItems": "center",
      "flexDirectionMobile": "row",
      "preserveMobileLayout": true,
      "width": "100%"
    },
    "children": ["order-by.v2"]
  },

  "search-result-layout.desktop#department": {
    "title": "Search Result Layout Desktop Department",
    "children": [
      "custom-div#breadcrumb-search",
      "custom-category-banners#custom",
      "custom-search-carousel#default",
      "custom-div#filter-and-products",
      "custom-department-description#default"
    ],
    "props": {
      "pagination": "show-more",
      "preventRouteChange": false,
      "defaultGalleryLayout": "grid"
    }
  },

  "custom-div#filter-and-products": {
    "title": "Filter and Products Container",
    "props": {
      "blockClass": ["filter-and-products", "container"],
      "justifyContent": "space-between",
      "alignItems": "flex-start",
      "flexDirectionMobile": "row",
      "preserveMobileLayout": true,
      "width": "100%",
      "gap": "1rem"
    },
    "children": [
      "filter-navigator.v3#custom",
      "custom-div#search-content-desktop"
    ]
  },

  "custom-div#search-content-desktop": {
    "title": "Search Content Desktop",
    "props": {
      "blockClass": ["search-content-desktop-col"],
      "justifyContent": "flex-start",
      "alignItems": "flex-start",
      "flexDirectionMobile": "row",
      "flexDirection": "column",
      "preserveMobileLayout": true,
      "width": "100%",
      "gap": "55px"
    },
    "children": [
      "custom-div#search-info",
      "search-content#default",
      "search-fetch-more"
    ]
  },

  "rich-text#search-end-description": {
    "title": "Descricao da Departamento - Final da pagina",
    "props": {
      "blockClass": ["department-end-description"],
      "text": "## Feminina\n\n Duis non quam et nisi tincidunt fermentum. Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. Nullam ullamcorper, mauris nec feugiat fermentum, purus lacus suscipit felis, et facilisis justo lacus id risus. Sed at risus vel nulla consequat fermentum. Donec et orci mauris. Nullam tempor velit id mi luctus, a scelerisque libero accumsan. In hac habitasse platea dictumst. Cras ac nunc nec massa tristique fringilla. \n\n Mauris vitae quam in justo dictum sodales. In eget tortor a nunc vehicula tempor. Nam ac tincidunt ipsum, eget accumsan nisi. Praesent porta, magna vitae dapibus pharetra, erat eros efficitur nunc, in mattis lectus libero a velit. Nulla facilisi. Curabitur tincidunt, felis a elementum tincidunt, ex felis fermentum dui, eget pulvinar arcu eros eu eros. Vestibulum sollicitudin pretium velit, eget volutpat justo fermentum sit amet. Pellentesque in nulla in nisi dictum interdum."
    }
  },

  "custom-div#department-banner-desktop": {
    "title": "Banner Department",
    "props": {
      "width": "100%",
      "blockClass": ["department-banner"]
    },
    "children": ["search-title.v2", "image#search-banner-department"]
  },

  "custom-div#department-banner-mobile": {
    "title": "Banner Department Mobile",
    "props": {
      "width": "100%",
      "blockClass": ["department-banner"]
    },
    "children": [
      "search-title.v2#department",
      "image#search-banner-department-mobile"
    ]
  },

  "search-title.v2#department": {
    "props": {
      "blockClass": ["department-title"]
    }
  },

  "responsive-layout.desktop#department-banner": {
    "title": "Department Banner Desktop",
    "children": ["custom-div#department-banner-desktop"]
  },

  "responsive-layout.tablet#department-banner": {
    "title": "Department Tablet Banner",
    "children": ["custom-div#department-banner-desktop"]
  },

  "responsive-layout.phone#department-banner": {
    "title": "Department Phone Banner",
    "children": ["custom-div#department-banner-mobile"]
  },

  "image#search-banner-department": {
    "props": {
      "blockClass": ["department-banner-image"],
