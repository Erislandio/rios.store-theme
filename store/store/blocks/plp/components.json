{
  "custom-div#filter": {
    "title": "Filter Container",
    "props": {
      "blockClass": ["filter-container", "container", "filter-search"],
      "justifyContent": "space-between",
      "alignItems": "center",
      "flexDirectionMobile": "row",
      "preserveMobileLayout": true,
      "width": "100%"
    },
    "children": ["drawer#filters", "gallery-layout-switcher"]
  },

  "custom-div#filter-department": {
    "title": "Filter Container",
    "props": {
      "blockClass": ["filter-container", "container", "filter-department"],
      "justifyContent": "space-between",
      "alignItems": "center",
      "flexDirectionMobile": "row",
      "preserveMobileLayout": true,
      "width": "100%"
    },
    "children": ["gallery-layout-switcher"]
  },

  "custom-div#search-info": {
    "title": "Orderby Container",
    "props": {
      "blockClass": ["orderby-container", "container"],
      "justifyContent": "space-between",
      "alignItems": "center",
      "flexDirectionMobile": "row",
      "preserveMobileLayout": true,
      "width": "100%"
    },
    "children": ["custom-div#search-info-first", "custom-div#search-info-last"]
  },

  "custom-div#search-info-first": {
    "title": "Orderby Container ",
    "props": {
      "blockClass": ["orderby-container--first"],
      "justifyContent": "flex-start",
      "alignItems": "center",
      "flexDirectionMobile": "row",
      "preserveMobileLayout": true,
      "width": "100%",
      "gap": "104px",
      "padding": "0px"
    },
    "children": ["search-title.v2", "total-products.v2"]
  },

  "custom-div#search-info-last": {
    "title": "Orderby Container ",
    "props": {
      "blockClass": ["orderby-container--last"],
      "justifyContent": "flex-end",
      "alignItems": "center",
      "flexDirectionMobile": "row",
      "preserveMobileLayout": true,
      "width": "100%",
      "padding": "0px",
      "gap": "1rem"
    },
    "children": ["order-by.v2", "gallery-layout-switcher"]
  },

  "drawer#filters": {
    "props": {
      "blockClass": ["filter-drawer"],
      "position": "left",
      "closeOnOutsideClick": true
    },
    "children": ["filter-navigator.v3#custom"],
    "blocks": ["drawer-trigger#filters"]
  },

  "drawer-trigger#filters": {
    "props": {
      "blockClass": ["filter"]
    },
    "children": ["rich-text#filters"]
  },

  "filter-navigator.v3#custom": {
    "props": {
      "navigationTypeOnMobile": "collapsible",
      "blockClass": ["custom-filter-navigator"],
      "layout": "responsive",
      "closeOnOutsideClick": true
    }
  },

  "rich-text#filters": {
    "title": "Open Modal Text",
    "props": {
      "blockClass": ["open-drawer-filter"],
      "text": "Filtrar"
    }
  },

  "search-content#default": {
    "title": "Search Content",
    "props": {
      "blockClass": ["custom-gallery"]
    },
    "blocks": ["gallery#customv2", "not-found"]
  },

  "gallery#customv2": {
    "title": "Custom Gallery",
    "props": {
      "blockClass": ["custom-gallery"],
      "layouts": [
        {
          "name": "grid",
          "component": "GridSummary",
          "itemsPerRow": {
            "(min-width:1300px)": 3,
            "desktop": 3,
            "tablet": 3,
            "phone": 2
          }
        },
        {
          "name": "list",
          "component": "ListSummary",
          "itemsPerRow": 2
        }
      ],
      "ListSummary": "product-summary.shelf#default",
      "GridSummary": "product-summary.shelf#default"
    }
  }
}
